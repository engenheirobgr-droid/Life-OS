rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function legacyMigrationDoc(userId) {
      return signedIn() && (userId == 'meu-sistema-vida' || userId == 'meu-sistema-vida-images');
    }

    match /users/{userId} {
      allow read, write: if owns(userId) || legacyMigrationDoc(userId);

      match /push_subscriptions/{subscriptionId} {
        allow read, write: if owns(userId) || legacyMigrationDoc(userId);
      }

      match /push_logs/{logId} {
        allow read: if owns(userId) || legacyMigrationDoc(userId);
        allow write: if false;
      }
    }

    match /user_images/{userId} {
      allow read, write: if owns(userId);
    }
  }
}
