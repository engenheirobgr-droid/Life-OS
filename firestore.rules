rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if owns(userId);

      match /public/profile {
        allow read: if signedIn() && resource.data.sharingEnabled == true;
        allow create, update: if owns(userId)
          && request.resource.data.userId == userId
          && request.resource.data.sharingEnabled == true;
        allow delete: if owns(userId);
      }

      match /private/social {
        allow read, write: if owns(userId);

        match /inbox/{eventId} {
          allow read, update, delete: if owns(userId);
          allow create: if signedIn()
            && request.resource.data.targetUid == userId
            && request.resource.data.sourceUid == request.auth.uid;
        }
      }

      match /private/connections {
        allow read, write: if owns(userId);
      }

      match /private/engagement {
        allow read, write: if owns(userId);
      }

      match /push_subscriptions/{subscriptionId} {
        allow read, write: if owns(userId);
      }

      match /push_logs/{logId} {
        allow read: if owns(userId);
        allow write: if false;
      }
    }

    match /user_images/{userId} {
      allow read, write: if owns(userId);
    }

    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /socialChallenges/{challengeId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.participantUids;
      allow create: if signedIn()
        && request.resource.data.creatorUid == request.auth.uid
        && request.resource.data.targetUid != request.auth.uid
        && request.resource.data.participantUids.size() == 2
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.targetUid in request.resource.data.participantUids;
      allow update: if signedIn()
        && request.auth.uid in resource.data.participantUids
        && request.resource.data.creatorUid == resource.data.creatorUid
        && request.resource.data.targetUid == resource.data.targetUid
        && request.resource.data.participantUids == resource.data.participantUids
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }
  }
}
